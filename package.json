{
  "name": "gap-app",
  "version": "1.0.0",
  "description": "G.A.P. Portal - Full Stack Application",
  "private": true,
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test": "npm run test:backend && npm run test:frontend",
    "test:quiet": "cd backend && npm test -- --silent --no-verbose && cd ../frontend && npm test -- --silent --no-verbose",
    "test:integration": "cd backend && npm run test:integration",
    "test:integration:quiet": "cd backend && npm run test:integration:quiet",
    "format:backend": "cd backend && npm run format:check",
    "format:frontend": "cd frontend && npm run format:check",
    "format": "npm run format:backend && npm run format:frontend",
    "format:check": "npm run format",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "prepare": "husky || true",
    "test:e2e": "cd tests && npx playwright test",
    "test:e2e:quiet": "cd tests && npx playwright test --reporter=line",
    "test:e2e:headed": "cd tests && npx playwright test --headed",
    "test:e2e:report": "cd tests && npx playwright show-report",
    "test:e2e:allure": "cd tests && npx playwright test && npx allure generate -o allure-report && npx allure open allure-report"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
