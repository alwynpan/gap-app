{
  "name": "gap-app",
  "version": "1.0.0",
  "description": "G.A.P. Portal - Full Stack Application",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "install:all": "pnpm install",
    "lint:backend": "pnpm --filter gap-backend lint",
    "lint:frontend": "pnpm --filter gap-frontend lint",
    "lint": "pnpm run lint:backend && pnpm run lint:frontend",
    "test:backend": "pnpm --filter gap-backend test",
    "test:frontend": "pnpm --filter gap-frontend test",
    "test": "pnpm run test:backend && pnpm run test:frontend",
    "test:quiet": "pnpm --filter gap-backend test:quiet && pnpm --filter gap-frontend test:quiet",
    "test:integration": "pnpm --filter gap-backend test:integration",
    "test:integration:quiet": "pnpm --filter gap-backend test:integration:quiet",
    "format:backend": "pnpm --filter gap-backend format:check",
    "format:frontend": "pnpm --filter gap-frontend format:check",
    "format": "pnpm run format:backend && pnpm run format:frontend",
    "format:check": "pnpm run format",
    "build:backend": "pnpm --filter gap-backend build",
    "build:frontend": "pnpm --filter gap-frontend build",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "prepare": "husky || true",
    "test:e2e": "pnpm --filter gap-portal-e2e test",
    "test:e2e:quiet": "pnpm --filter gap-portal-e2e test -- --reporter=line",
    "test:e2e:headed": "pnpm --filter gap-portal-e2e test -- --headed",
    "test:e2e:report": "pnpm --filter gap-portal-e2e exec playwright show-report",
    "test:e2e:allure": "pnpm --filter gap-portal-e2e test && pnpm --filter gap-portal-e2e exec allure generate -o allure-report && pnpm --filter gap-portal-e2e exec allure open allure-report"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
