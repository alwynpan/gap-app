# Copy this file to .env and fill in values before running docker-compose.

# ── Database ────────────────────────────────────────────────────────────────
DB_PASSWORD=gap_password_dev

# ── Authentication ──────────────────────────────────────────────────────────
# Required: change this to a long random string in production
JWT_SECRET=dev-secret-change-in-production

# ── Admin seed account (used during first-time migration) ────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_in_production

# ── Feature flags ───────────────────────────────────────────────────────────
# Set to true to allow public self-registration via /auth/register
REGISTRATION_ENABLED=true

# ── SMTP (email) ────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable outbound email.
# When disabled, email content is logged to the backend console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@gap-app.local

# ── Frontend URL (used in email links) ──────────────────────────────────────
APP_URL=http://localhost:3000
