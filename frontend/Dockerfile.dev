FROM node:24-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

# Install all dependencies
COPY package*.json ./
RUN npm ci

# Source code is mounted as a volume in docker-compose
EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
