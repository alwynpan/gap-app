# ─────────────────────────────────────────────────────────────────────────────
# G.A.P. Production Environment Variables
# Copy this file to .env and fill in all required values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain & TLS ─────────────────────────────────────────────────────────────

# The fully-qualified domain name for the app. DNS must already point to this server.
# Required. No default.
DOMAIN=gap.example.com

# Email address for Let's Encrypt certificate registration and expiry notices.
# Required. No default.
LETSENCRYPT_EMAIL=admin@example.com

# ── Database ─────────────────────────────────────────────────────────────────

# Password for the PostgreSQL gap_user account.
# Required. No default.
DB_PASSWORD=

# ── Authentication ───────────────────────────────────────────────────────────

# Secret key used to sign JWT tokens. Use a long, random string (min 32 chars).
# Required. No default.
JWT_SECRET=

# Duration before JWT tokens expire. Uses ms/zeit format (e.g. 24h, 7d, 1h).
# Optional. Default: 24h
JWT_EXPIRES_IN=24h

# ── Admin Account ────────────────────────────────────────────────────────────
# These values are only used on the very first database migration to seed the
# initial admin account. Changing them after the first run has no effect.

# Username for the initial admin account.
# Required. No default.
ADMIN_USERNAME=

# Password for the initial admin account.
# Required. No default.
ADMIN_PASSWORD=

# ── Registration ─────────────────────────────────────────────────────────────

# Set to true to allow users to self-register. Recommended to keep false in
# production and let admins create user accounts manually.
# Optional. Default: false
REGISTRATION_ENABLED=false

# ── SMTP (Email) ─────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email sending. When disabled, setup links
# and password reset links are written to the backend container logs instead.

# SMTP server hostname (e.g. smtp.sendgrid.net). Leave blank to disable email.
# Optional. Default: (empty - email disabled)
SMTP_HOST=

# SMTP server port.
# Optional. Default: 587
SMTP_PORT=587

# Set to true to use TLS (SMTPS). Use false for STARTTLS on port 587.
# Optional. Default: false
SMTP_SECURE=false

# SMTP authentication username.
# Optional. Default: (empty)
SMTP_USER=

# SMTP authentication password.
# Optional. Default: (empty)
SMTP_PASS=

# The "From" address shown on outgoing emails.
# Optional. Default: no-reply@<DOMAIN>
SMTP_FROM=

# ── Database Backups ─────────────────────────────────────────────────────────
# Backups are written to ./backups/ relative to this docker-compose file.

# How often to run a backup, in minutes.
# Optional. Default: 1440 (every 24 hours)
BACKUP_FREQ=1440

# Time to start the first backup in HHMM format (24-hour clock).
# Optional. Default: 0300 (3:00 AM)
BACKUP_BEGIN=0300

# Delete backups older than this many minutes.
# Optional. Default: 10080 (7 days)
BACKUP_CLEANUP_TIME=10080
