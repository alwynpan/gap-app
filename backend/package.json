{
  "name": "gap-backend",
  "version": "1.0.0",
  "description": "G.A.P. Backend - Fastify API with JWT authentication",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "migrate:up": "node src/db/migrate.js up",
    "migrate:reset": "node src/db/migrate.js reset",
    "test": "jest --coverage",
    "lint": "eslint --max-warnings 0 --format checkstyle -o eslint.xml .",
    "lint:fix": "eslint --fix .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "build": "echo 'Backend build complete'"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/postgres": "^6.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "isomorphic-dompurify": "^3.7.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-checkstyle": "^9.0.1",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  }
}
