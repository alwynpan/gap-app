{
  "name": "gap-backend",
  "version": "1.0.0",
  "description": "G.A.P. Backend - Fastify API with JWT authentication",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "migrate:up": "node src/db/migrate.js up",
    "test": "jest --coverage",
    "lint": "eslint --max-warnings 0 --format checkstyle -o eslint.xml .",
    "lint:fix": "eslint --fix .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "build": "echo 'Backend build complete'"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/postgres": "^6.0.0",
    "@fastify/rate-limit": "^8.0.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.0",
    "fastify": "^4.25.0",
    "fastify-bcrypt": "^1.0.1",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-security": "^2.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.0.0",
    "prettier": "^3.8.1"
  }
}
